{
  "manifest_version": 3,
  "name": "SR Auto",
  "version": "1.1",
  "description": "Asystent automatyzacji zadań z wbudowanym czatem AI.",
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "sidePanel",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://openrouter.ai/",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Otwórz panel SR Auto"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/inPageHelper.js"],
      "css": ["styles/inPageHelper.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content-scripts/scrapper.js",
        "styles/custom-checkbox.css",
        "content-scripts/botFilter.js",
        "styles/botFilter.css",
        "content-scripts/getSelectedBotUrls.js",
        "images/icon48.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}